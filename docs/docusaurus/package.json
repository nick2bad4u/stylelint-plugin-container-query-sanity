{
    "$schema": "https://www.schemastore.org/package.json",
    "name": "@stylelint-plugin-container-query-sanity/docs",
    "version": "0.1.0",
    "private": true,
    "description": "Docusaurus documentation site for stylelint-plugin-container-query-sanity.",
    "keywords": [
        "docusaurus",
        "documentation",
        "stylelint",
        "stylelint-plugin",
        "css"
    ],
    "homepage": "https://nick2bad4u.github.io/stylelint-plugin-container-query-sanity/",
    "bugs": {
        "url": "https://github.com/Nick2bad4u/stylelint-plugin-container-query-sanity/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Nick2bad4u/stylelint-plugin-container-query-sanity.git"
    },
    "license": "MIT",
    "author": "Nick2bad4u",
    "contributors": [
        {
            "name": "Nick2bad4u",
            "email": "20943337+Nick2bad4u@users.noreply.github.com",
            "url": "https://nick2bad4u.github.io/stylelint-plugin-container-query-sanity"
        }
    ],
    "sideEffects": false,
    "main": "docusaurus.config.ts",
    "files": [
        "site-docs"
    ],
    "scripts": {
        "build": "npm run docs:api && npm --prefix ../.. run build:eslint-inspector && npm --prefix ../.. run build:stylelint-inspector && docusaurus build",
        "build:fast": "cross-env DOCUSAURUS_ENABLE_EXPERIMENTAL=true docusaurus build",
        "build:local": "npm run docs:api && npm --prefix ../.. run build:eslint-inspector:local && npm --prefix ../.. run build:stylelint-inspector:local && cross-env NODE_OPTIONS=--no-deprecation docusaurus build",
        "clear": "docusaurus clear",
        "deploy": "docusaurus deploy",
        "docs:api": "typedoc --options typedoc.config.json",
        "docusaurus": "docusaurus",
        "serve": "docusaurus serve",
        "start": "docusaurus start --host localhost",
        "start:devtools": "cross-env DOCUSAURUS_BASE_URL=/ docusaurus start --host localhost",
        "type:css": "npx typed-css-modules .\\src",
        "typecheck": "tsc --project tsconfig.json --noEmit && tsc --project tsconfig.typedoc.json --noEmit",
        "write-heading-ids": "docusaurus write-heading-ids",
        "write-translations": "docusaurus write-translations"
    },
    "dependencies": {
        "@docusaurus/core": "^3.10.1",
        "@docusaurus/faster": "^3.10.1",
        "@docusaurus/plugin-content-docs": "^3.10.1",
        "@docusaurus/plugin-pwa": "^3.10.1",
        "@docusaurus/preset-classic": "^3.10.1",
        "@docusaurus/theme-mermaid": "^3.10.1",
        "@docusaurus/types": "^3.10.1",
        "@easyops-cn/docusaurus-search-local": "^0.55.1",
        "clsx": "^2.1.1",
        "prism-react-renderer": "^2.4.1"
    },
    "devDependencies": {
        "@docusaurus/module-type-aliases": "^3.10.1",
        "@docusaurus/tsconfig": "^3.10.1",
        "@eslint/config-inspector": "^3.0.2",
        "@mdx-js/react": "^3.1.1",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "docusaurus-plugin-image-zoom": "^3.0.1",
        "react": "^19.2.6",
        "react-dom": "^19.2.6",
        "react-github-btn": "^1.4.0",
        "typed-css-modules": "^0.9.1",
        "typedoc": "^0.28.19",
        "typedoc-docusaurus-theme": "^1.4.2",
        "typedoc-plugin-coverage": "^4.0.3",
        "typedoc-plugin-dt-links": "^2.0.55",
        "typedoc-plugin-external-package-links": "^0.2.0",
        "typedoc-plugin-markdown": "^4.11.0",
        "typedoc-plugin-mdn-links": "^5.1.1",
        "typedoc-plugin-missing-exports": "^4.1.3",
        "typedoc-plugin-remark": "^2.0.1",
        "typedoc-plugin-rename-defaults": "^0.7.3",
        "typedoc-plugin-replace-text": "^4.2.0",
        "typescript": "^6.0.3"
    },
    "peerDependencies": {
        "react": "^19.2.4",
        "react-dom": "^19.2.4"
    },
    "packageManager": "npm@11.14.1",
    "engines": {
        "node": ">=22.0.0"
    },
    "devEngines": {
        "runtime": {
            "name": "node",
            "version": ">=22.0.0",
            "onFail": "error"
        },
        "packageManager": {
            "name": "npm",
            "version": ">=11.0.0",
            "onFail": "error"
        }
    }
}
